---
const USE_CASES = [
  {
    title: "Clínicas y Consultorios",
    tag: "Salud y Bienestar",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    color: "from-brand-purple to-indigo-500",
    details: [
      "Agendamiento automático de consultas físicas y teleconsultas.",
      "Pre-calificación del paciente mediante preguntas de síntomas básicos.",
      "Recordatorios automáticos antes de la cita para reducir inasistencias."
    ]
  },
  {
    title: "Restaurantes y Cafés",
    tag: "Hostelería",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>`,
    color: "from-brand-green to-teal-500",
    details: [
      "Reservas automáticas para mesas de grupos grandes o parejas.",
      "Pregunta y registro de restricciones dietéticas (alergias, vegano).",
      "Listas de espera automáticas cuando el local se llena."
    ]
  },
  {
    title: "Agencias Inmobiliarias",
    tag: "Bienes Raíces",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
    color: "from-blue-500 to-cyan-500",
    details: [
      "Calificación de presupuesto y enganche de leads interesados.",
      "Envío instantáneo de fichas técnicas por el mismo chat.",
      "Agendamiento de visitas presenciales con el asesor de la zona."
    ]
  },
  {
    title: "Academias y Cursos",
    tag: "Educación",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222 4 2.222V20"/></svg>`,
    color: "from-yellow-500 to-amber-500",
    details: [
      "Inscripción automatizada a webinars o clases de prueba gratuitas.",
      "Respuestas rápidas sobre costos, horarios y temarios disponibles.",
      "Derivación inteligente a asesores para resolver planes de pago."
    ]
  },
  {
    title: "Servicios Profesionales",
    tag: "Servicios",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
    color: "from-pink-500 to-rose-500",
    details: [
      "Filtro inicial y categorización de consultas o solicitudes.",
      "Respuestas autónomas a preguntas frecuentes de facturación.",
      "Transferencia automática a humanos cuando es necesario."
    ]
  },
  {
    title: "Servicios Locales",
    tag: "Servicios del Hogar",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>`,
    color: "from-purple-500 to-indigo-600",
    details: [
      "Cotización dinámica basada en tipo de servicio y tamaño.",
      "Registro inmediato de la dirección y datos de contacto.",
      "Agendamiento de la visita del personal y confirmación automática."
    ]
  }
];
---

<section id="casos" class="py-20 relative overflow-hidden bg-brand-dark/20 border-t border-white/5">
  <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-brand-purple/5 rounded-full blur-[140px] pointer-events-none -z-10"></div>
  
  <div class="mx-auto max-w-7xl px-6">
    <!-- Header Section -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="inline-flex items-center gap-2 rounded-full border border-brand-green/30 bg-brand-green/10 px-3 py-1 text-xs text-brand-green font-medium mb-4">
        Casos de Uso
      </div>
      <h2 class="font-display text-3xl sm:text-4xl font-extrabold text-white mb-4">
        Handl se Adapta a Cualquier Tipo de Negocio
      </h2>
      <p class="text-gray-400">
        Ya sea una clínica, restaurante o agencia inmobiliaria, el recepcionista virtual se personaliza según las necesidades específicas de tu industria.
      </p>
    </div>

    <!-- Grid of Use Cases -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {USE_CASES.map((useCase) => (
        <div class="group relative rounded-2xl border border-white/5 bg-brand-surface/30 p-6 backdrop-blur-xl transition-all duration-300 hover:border-white/10 hover:bg-brand-surface/40 hover:-translate-y-1">
          <!-- Glow effect under card icon -->
          <div class="absolute -top-3 -left-3 w-12 h-12 bg-white/5 rounded-xl blur-xl group-hover:bg-brand-purple/10 transition-colors"></div>
          
          <!-- Card Header -->
          <div class="flex items-center justify-between mb-5">
            <div class={`flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br ${useCase.color} text-white shadow-md`}>
              <Fragment set:html={useCase.icon} />
            </div>
            <span class="rounded-full bg-white/5 border border-white/10 px-2.5 py-1 text-[10px] text-gray-400 font-semibold tracking-wider uppercase">
              {useCase.tag}
            </span>
          </div>

          <!-- Title -->
          <h3 class="font-display text-lg font-bold text-white mb-4 group-hover:text-brand-purple transition-colors">
            {useCase.title}
          </h3>

          <!-- Details List -->
          <ul class="flex flex-col gap-3 text-xs text-gray-400 mb-6 leading-relaxed flex-1">
            {useCase.details.map((detail) => (
              <li class="flex items-start gap-2.5">
                <svg class="w-4 h-4 text-brand-green shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
                <span>{detail}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
