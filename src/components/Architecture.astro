---
const STEPS = [
  {
    num: "01",
    title: "Configuración Inicial",
    desc: "Definimos la personalidad de tu recepcionista, las FAQs de tu negocio, tu catálogo de servicios y los criterios de calificación de leads."
  },
  {
    num: "02",
    title: "Conexión con WhatsApp",
    desc: "Vinculamos tu número de WhatsApp Business. El recepcionista IA empieza a recibir mensajes de tus clientes de forma automática."
  },
  {
    num: "03",
    title: "Atención Inteligente",
    desc: "El recepcionista responde preguntas, califica interesados y gestiona objeciones con la voz y tono de tu marca, 24/7."
  },
  {
    num: "04",
    title: "Agendamiento Automático",
    desc: "Cuando un cliente quiere una cita, el recepcionista agenda directamente en tu Google Calendar con enlace de Meet incluido."
  },
  {
    num: "05",
    title: "Seguimiento y Reportes",
    desc: "Recibe un reporte diario de leads calificados, citas agendadas y conversaciones pendientes. Tú decides cuándo y cómo escalar."
  }
];

const CUSTOMIZATIONS = [
  {
    title: "Personalidad del Bot",
    description: "Elige el tono: profesional, casual, amigable. Define cómo saluda, cómo despide y cómo maneja objeciones.",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>`
  },
  {
    title: "Flujos de Calificación",
    description: "Define las preguntas que el bot hará para filtrar leads: presupuesto, urgencia, ubicación, o cualquier criterio de tu negocio.",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>`
  },
  {
    title: "Integraciones",
    description: "Conecta con Google Calendar, tu CRM, sistema de reservas o cualquier herramienta que ya uses en tu negocio.",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/></svg>`
  },
  {
    title: "Horarios y Disponibilidad",
    description: "Establece horarios de atención, bloquea vacaciones y sincroniza la disponibilidad real de tu equipo o espacio.",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`
  }
];
---

<section id="arquitectura" class="py-20 relative overflow-hidden bg-brand-dark border-t border-white/5">
  <div class="absolute bottom-1/4 left-1/2 -translate-x-1/2 w-[550px] h-[550px] bg-brand-purple/5 rounded-full blur-[140px] pointer-events-none -z-10"></div>
  
  <div class="mx-auto max-w-7xl px-6">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="inline-flex items-center gap-2 rounded-full border border-brand-purple/30 bg-brand-purple/10 px-3 py-1 text-xs text-brand-purple font-medium mb-4">
        Cómo Funciona
      </div>
      <h2 class="font-display text-3xl sm:text-4xl font-extrabold text-white mb-4">
        Un Recepcionista Virtual Hecho a la Medida de Tu Negocio
      </h2>
      <p class="text-gray-400">
        Handl se adapta a la forma en que tú trabajas. Desde la personalidad del bot hasta los flujos de calificación, todo es personalizable según tus necesidades.
      </p>
    </div>

    <!-- Client Flow Steps -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-20">
      {STEPS.map((step) => (
        <div class="relative rounded-2xl border border-white/5 bg-brand-surface/30 p-6 backdrop-blur-xl overflow-hidden group">
          <div class="absolute -top-6 -right-6 font-display font-extrabold text-7xl text-white/5 select-none transition-transform duration-300 group-hover:scale-110">
            {step.num}
          </div>
          
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-brand-purple/10 text-brand-purple font-mono font-bold text-xs mb-4">
            {step.num}
          </span>
          <h3 class="font-display text-base font-bold text-white mb-2">
            {step.title}
          </h3>
          <p class="text-xs text-gray-400 leading-relaxed">
            {step.desc}
          </p>
        </div>
      ))}
    </div>

    <!-- Customization Section -->
    <div class="text-center max-w-3xl mx-auto mb-12">
      <div class="inline-flex items-center gap-2 rounded-full border border-brand-green/30 bg-brand-green/10 px-3 py-1 text-xs text-brand-green font-medium mb-4">
        100% Personalizable
      </div>
      <h3 class="font-display text-2xl sm:text-3xl font-extrabold text-white mb-4">
        Tú Defines Cómo Funciona Tu Recepcionista
      </h3>
      <p class="text-gray-400">
        Cada negocio es único. Handl se adapta a tus procesos, no al revés.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {CUSTOMIZATIONS.map((item) => (
        <div class="group relative overflow-hidden rounded-2xl border border-white/5 bg-brand-surface/30 p-6 backdrop-blur-xl transition-all duration-300 hover:border-brand-green/20 hover:bg-brand-surface/40">
          <div class="absolute inset-0 bg-gradient-to-r from-brand-green/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 -z-10"></div>
          
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-green/10 text-brand-green mb-4 group-hover:scale-110 transition-transform">
            <Fragment set:html={item.icon} />
          </div>

          <h4 class="font-display text-base font-bold text-white mb-2">
            {item.title}
          </h4>

          <p class="text-xs text-gray-400 leading-relaxed">
            {item.description}
          </p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div id="contacto" class="mt-20 rounded-3xl border border-brand-purple/20 bg-gradient-to-r from-brand-purple/10 via-brand-surface/30 to-brand-green/5 p-8 sm:p-12 text-center relative overflow-hidden backdrop-blur-2xl">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] bg-brand-purple/10 rounded-full blur-[80px] pointer-events-none -z-10"></div>
      
      <h3 class="font-display text-2xl sm:text-3xl font-extrabold text-white mb-4">
        ¿Listo para Automatizar tu Negocio en WhatsApp?
      </h3>
      <p class="text-gray-400 max-w-xl mx-auto mb-8 text-sm sm:text-base leading-relaxed">
        Solicita una demo gratuita y descubre cómo Handl puede transformar la atención al cliente de tu negocio. Sin compromisos, sin tarjeta de crédito.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a 
          href="#contacto" 
          class="w-full sm:w-auto inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-brand-purple to-brand-green p-[1.5px] font-semibold text-white transition-all duration-300 hover:shadow-[0_0_24px_rgba(139,92,246,0.4)]"
        >
          <span class="w-full rounded-[10px] bg-brand-dark px-6 py-3 text-sm transition-colors duration-300 hover:bg-transparent flex items-center justify-center gap-2">
            Solicitar Demo Gratuita
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </span>
        </a>
        <a 
          href="#demo" 
          class="w-full sm:w-auto inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-6 py-3 text-sm font-semibold text-white transition-colors duration-200 hover:bg-white/10"
        >
          Ver Demo Interactiva
        </a>
      </div>
    </div>

  </div>
</section>
