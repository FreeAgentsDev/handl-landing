---

<footer class="w-full border-t border-white/5 bg-brand-dark/40 py-12 relative overflow-hidden">
  <div class="absolute -bottom-20 left-1/2 -translate-x-1/2 w-[800px] h-[150px] bg-brand-purple/5 rounded-full blur-[100px] pointer-events-none -z-10"></div>
  
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
      <!-- Branding Column -->
      <div class="md:col-span-2 flex flex-col gap-4">
        <a href="#" class="flex items-center gap-2">
          <img src="/handl.png" alt="Handl Logo" class="h-12 w-12 rounded-lg object-cover" />
          <div class="flex flex-col">
            <span class="font-display text-base font-bold tracking-tight text-white">
              Handl
            </span>
            <span class="text-[9px] uppercase tracking-wider text-gray-500 font-sans -mt-1">
              by freeagents
            </span>
          </div>
        </a>
        <p class="text-sm text-gray-400 max-w-sm mt-2 leading-relaxed">
          Recepcionista virtual con IA para WhatsApp. Califica leads, agenda citas en Google Calendar y atiende a tus clientes 24/7 de forma automática y profesional.
        </p>
      </div>

      <!-- Links Column 1 -->
      <div>
        <h4 class="font-display text-sm font-semibold text-white mb-4">Producto</h4>
        <ul class="flex flex-col gap-2.5 text-sm text-gray-400">
          <li><a href="#casos" class="hover:text-white transition-colors">Casos de Uso</a></li>
          <li><a href="#demo" class="hover:text-white transition-colors">Demo Interactiva</a></li>
          <li><a href="#features" class="hover:text-white transition-colors">Beneficios</a></li>
          <li><a href="#contacto" class="hover:text-white transition-colors">Solicitar Demo</a></li>
        </ul>
      </div>

      <!-- Links Column 2 -->
      <div>
        <h4 class="font-display text-sm font-semibold text-white mb-4">Cumplimiento</h4>
        <ul class="flex flex-col gap-2.5 text-sm text-gray-400">
          <li><a href="#cumplimiento" class="hover:text-white transition-colors">Políticas Meta 2026</a></li>
          <li><a href="https://developers.facebook.com/docs/whatsapp/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Meta WhatsApp API</a></li>
          <li><a href="#arquitectura" class="hover:text-white transition-colors">Arquitectura</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="flex flex-col sm:flex-row items-center justify-between border-t border-white/5 pt-8 gap-4 text-xs text-gray-500">
      <p>© {new Date().getFullYear()} Handl by FreeAgents. Todos los derechos reservados.</p>
      <div class="flex items-center gap-6">
        <a href="#contacto" class="hover:text-gray-400 transition-colors">Solicitar Demo</a>
        <a href="#" class="hover:text-gray-400 transition-colors">Políticas de Privacidad</a>
      </div>
    </div>
  </div>
</footer>
