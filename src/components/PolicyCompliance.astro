---
---

<section id="cumplimiento" class="py-20 relative overflow-hidden bg-brand-dark/20 border-t border-white/5">
  <div class="absolute top-1/2 left-1/4 w-[450px] h-[450px] bg-brand-green/5 rounded-full blur-[130px] pointer-events-none -z-10"></div>
  
  <div class="mx-auto max-w-7xl px-6">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="inline-flex items-center gap-2 rounded-full border border-brand-green/30 bg-brand-green/10 px-3 py-1 text-xs text-brand-green font-medium mb-4">
        Seguridad y Confianza
      </div>
      <h2 class="font-display text-3xl sm:text-4xl font-extrabold text-white mb-4">
        Tu Número de WhatsApp Está Seguro con Handl
      </h2>
      <p class="text-gray-400">
        Cumplimos estrictamente con las normativas de Meta para WhatsApp Business API. Tu número está protegido y tu negocio opera con total tranquilidad.
      </p>
    </div>

    <!-- Benefits Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- Card 1 -->
      <div class="rounded-2xl border border-white/5 bg-brand-surface/30 p-6 backdrop-blur-xl relative overflow-hidden group">
        <div class="absolute top-0 left-0 w-full h-[3px] bg-brand-green/50"></div>
        <div class="flex items-center gap-2 text-brand-green font-semibold mb-4 text-sm font-display">
          <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
          Sin Spam ni Bloqueos
        </div>
        <p class="text-xs text-gray-400 leading-relaxed">
          Handl nunca envía mensajes promocionales no solicitados. Solo responde cuando tus clientes escriben, dentro de la ventana de servicio autorizada por Meta.
        </p>
      </div>

      <!-- Card 2 -->
      <div class="rounded-2xl border border-white/5 bg-brand-surface/30 p-6 backdrop-blur-xl relative overflow-hidden group">
        <div class="absolute top-0 left-0 w-full h-[3px] bg-brand-green/50"></div>
        <div class="flex items-center gap-2 text-brand-green font-semibold mb-4 text-sm font-display">
          <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
          Bot Personalizado para Tu Negocio
        </div>
        <p class="text-xs text-gray-400 leading-relaxed">
          Cada recepcionista está configurado exclusivamente con la información de tu empresa: servicios, precios, FAQs y politique de atención.
        </p>
      </div>

      <!-- Card 3 -->
      <div class="rounded-2xl border border-white/5 bg-brand-surface/30 p-6 backdrop-blur-xl relative overflow-hidden group">
        <div class="absolute top-0 left-0 w-full h-[3px] bg-brand-green/50"></div>
        <div class="flex items-center gap-2 text-brand-green font-semibold mb-4 text-sm font-display">
          <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          Transferencia a Humano
        </div>
 <p class="text-xs text-gray-400 leading-relaxed">
          Si un cliente lo solicita o detecta frustración, el recepcionista transfiere la conversación a un agente humano de tu equipo de forma inmediata.
        </p>
      </div>

    </div>
    
    <!-- Info banner -->
    <div class="mt-12 rounded-2xl border border-white/5 bg-brand-surface/30 p-6 flex flex-col sm:flex-row items-center justify-between gap-6 backdrop-blur-xl">
      <div class="flex items-center gap-4">
        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-brand-green/20 text-brand-green">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <div>
          <h4 class="font-display font-bold text-white text-sm">Soporte Dedicado para Tu Negocio</h4>
          <p class="text-xs text-gray-400 mt-1">
            Nuestro equipo te acompaña en la configuración inicial y está disponible para ajustar el recepcionista según las necesidades cambiantes de tu negocio.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
