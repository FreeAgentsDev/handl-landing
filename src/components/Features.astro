---
const FEATURES = [
  {
    title: "Atención 24/7 en WhatsApp",
    description: "Tu negocio nunca cierra. El recepcionista IA responde a tus clientes a cualquier hora del día o de la noche, los fines de semana y feriados incluidos.",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`
  },
  {
    title: "Calificación Automática de Leads",
    description: "El bot identifica a los clientes con mayor potencial de compra, recopila sus datos clave y los clasifica para que tu equipo solo invierta tiempo en los mejores prospectos.",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`
  },
  {
    title: "Agendamiento en Google Calendar",
    description: "Las citas se crean automáticamente en el calendario de tu negocio con enlace de Google Meet incluido. Sin doble reserva, sin llamadas perdidas.",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`
  },
  {
    title: "Cumplimiento con Meta 2026",
    description: "Handl está diseñado bajo las normativas oficiales de WhatsApp Business API. Evita bloqueos de números y protege la reputación de tu negocio.",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`
  },
  {
    title: "Onboarding en Minutos",
    description: "Configura tu recepcionista de WhatsApp en pocos pasos. Sin instalaciones complicadas, sin equipo técnico. Te guiamos en todo el proceso.",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`
  },
  {
    title: "Escalabilidad sin Límites",
    description: "Atiende cientos de conversaciones simultáneas sin perder calidad. La infraestructura crece con tu negocio sin costos ocultos.",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>`
  }
];
---

<section id="features" class="py-20 relative overflow-hidden bg-brand-dark border-t border-white/5">
  <!-- Subtle purple blur -->
  <div class="absolute top-1/4 right-0 w-[500px] h-[500px] bg-brand-purple/5 rounded-full blur-[160px] pointer-events-none -z-10"></div>
  
  <div class="mx-auto max-w-7xl px-6">
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row items-start md:items-end justify-between mb-16 gap-6">
      <div class="max-w-xl">
        <div class="inline-flex items-center gap-2 rounded-full border border-brand-purple/30 bg-brand-purple/10 px-3 py-1 text-xs text-brand-purple font-medium mb-4">
          Beneficios Clave
        </div>
        <h2 class="font-display text-3xl sm:text-4xl font-extrabold text-white leading-tight">
          Todo lo que tu Negocio Necesita en un Solo Lugar
        </h2>
      </div>
      <p class="text-gray-400 max-w-md leading-relaxed">
        Handl no es solo un chatbot. Es un recepcionista virtual completo que trabaja por ti las 24 horas del día, los 7 días de la semana.
      </p>
    </div>

    <!-- Features Bento-Grid style -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {FEATURES.map((feat) => (
        <div class="group relative overflow-hidden rounded-2xl border border-white/5 bg-brand-surface/30 p-8 backdrop-blur-xl transition-all duration-300 hover:border-brand-purple/20 hover:bg-brand-surface/40">
          <!-- Hover light border effect -->
          <div class="absolute inset-0 bg-gradient-to-r from-brand-purple/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 -z-10"></div>
          
          <!-- Icon -->
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-purple/10 text-brand-purple mb-6 group-hover:scale-110 transition-transform">
            <Fragment set:html={feat.icon} />
          </div>

          <!-- Title -->
          <h3 class="font-display text-lg font-bold text-white mb-3">
            {feat.title}
          </h3>

          <!-- Description -->
          <p class="text-xs text-gray-400 leading-relaxed">
            {feat.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
