---
---

<section class="relative overflow-hidden pt-24 pb-16 md:pt-32 md:pb-24">
  <!-- Subtle gradient glow behind hero -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-purple/10 rounded-full blur-[160px] pointer-events-none -z-10"></div>
  
  <div class="mx-auto max-w-7xl px-6 flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
    <!-- Hero Copy -->
    <div class="flex-1 flex flex-col text-center lg:text-left items-center lg:items-start">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 rounded-full border border-brand-purple/30 bg-brand-purple/10 px-3 py-1 text-xs text-brand-purple font-medium mb-6">
        <span class="flex h-2 w-2 rounded-full bg-brand-purple animate-pulse"></span>
        Plataforma SaaS Multi-tenant & Open Source
      </div>
      
      <!-- Headline -->
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-white leading-[1.1] mb-6">
        Recepcionistas con IA en <span class="bg-gradient-to-r from-brand-purple via-blue-400 to-brand-green bg-clip-text text-transparent">WhatsApp</span> para tu negocio
      </h1>
      
      <!-- Sub-headline -->
      <p class="text-lg text-gray-400 leading-relaxed max-w-xl mb-8">
        Despliega contestadores automáticos inteligentes con la personalidad de tu marca. Califica interesados, responde FAQs y agenda reuniones directamente en Google Calendar. Todo en piloto automático, 24/7, y en estricto cumplimiento con las normativas de Meta.
      </p>
      
      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
        <a 
          href="#demo" 
          class="inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-brand-purple to-brand-green p-[1.5px] font-semibold text-white transition-all duration-300 hover:shadow-[0_0_24px_rgba(139,92,246,0.4)]"
        >
          <span class="w-full rounded-[10px] bg-brand-dark px-6 py-3.5 text-base transition-colors duration-300 hover:bg-transparent flex items-center justify-center gap-2">
            Probar Demo Interactiva
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </span>
        </a>
        <a 
          href="#casos" 
          class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-6 py-3.5 text-base font-semibold text-white transition-colors duration-200 hover:bg-white/10 hover:border-white/20"
        >
          Explorar Casos de Uso
        </a>
      </div>

      <!-- Micro Features list -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-6 mt-12 w-full max-w-lg border-t border-white/5 pt-8 text-left">
        <div>
          <div class="text-sm font-bold text-white font-display">100% Sin Spam</div>
          <div class="text-xs text-gray-500 mt-1">Cumplimiento Meta 2026</div>
        </div>
        <div>
          <div class="text-sm font-bold text-white font-display">Multi-Tenant</div>
          <div class="text-xs text-gray-500 mt-1">Workspaces aislados</div>
        </div>
        <div class="col-span-2 sm:col-span-1">
          <div class="text-sm font-bold text-white font-display">OAuth Google</div>
          <div class="text-xs text-gray-500 mt-1">Agendamiento en Calendar</div>
        </div>
      </div>
    </div>
    
    <!-- Hero Mockup / Dashboard snippet -->
    <div class="flex-1 w-full max-w-xl lg:max-w-none">
      <div class="relative rounded-2xl border border-white/5 bg-brand-surface/40 p-1.5 backdrop-blur-xl shadow-2xl">
        <!-- Floating Stats Panel -->
        <div class="absolute -top-6 -left-6 hidden sm:flex items-center gap-3 rounded-xl border border-white/5 bg-brand-dark/90 p-4 shadow-lg backdrop-blur-lg animate-bounce" style="animation-duration: 8s;">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-green/20 text-brand-green">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <div class="text-xs text-gray-500">Citas Agendadas</div>
            <div class="text-sm font-bold text-white font-display">+184 esta semana</div>
          </div>
        </div>

        <div class="absolute -bottom-6 -right-6 hidden sm:flex items-center gap-3 rounded-xl border border-white/5 bg-brand-dark/90 p-4 shadow-lg backdrop-blur-lg animate-pulse">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-purple/20 text-brand-purple">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <div class="text-xs text-gray-500">Leads Calificados</div>
            <div class="text-sm font-bold text-white font-display">89.4% Conversión</div>
          </div>
        </div>

        <!-- Window Mockup -->
        <div class="rounded-xl overflow-hidden bg-brand-dark/90 border border-white/5 shadow-inner">
          <!-- Window Header -->
          <div class="flex items-center justify-between bg-brand-surface/40 px-4 py-3 border-b border-white/5">
            <div class="flex items-center gap-2">
              <div class="h-3 w-3 rounded-full bg-red-500/80"></div>
              <div class="h-3 w-3 rounded-full bg-yellow-500/80"></div>
              <div class="h-3 w-3 rounded-full bg-green-500/80"></div>
            </div>
            <span class="text-xs font-medium text-gray-500 font-sans">Handl Tenant Portal</span>
            <div class="w-12"></div>
          </div>
          
          <!-- Window Content -->
          <div class="p-6 flex flex-col gap-6 text-sm text-gray-400">
            <!-- Metric Overview -->
            <div class="grid grid-cols-3 gap-4">
              <div class="rounded-lg bg-white/5 p-3 border border-white/5">
                <div class="text-[10px] text-gray-500 uppercase font-sans">LLM Cost (Microcents)</div>
                <div class="text-base font-bold text-white font-display mt-0.5">$0.245</div>
              </div>
              <div class="rounded-lg bg-white/5 p-3 border border-white/5">
                <div class="text-[10px] text-gray-500 uppercase font-sans">Conversaciones</div>
                <div class="text-base font-bold text-white font-display mt-0.5">342</div>
              </div>
              <div class="rounded-lg bg-white/5 p-3 border border-white/5">
                <div class="text-[10px] text-gray-500 uppercase font-sans">Google Calendar</div>
                <div class="text-xs font-semibold text-brand-green flex items-center gap-1 mt-1">
                  <span class="h-1.5 w-1.5 bg-brand-green rounded-full"></span>
                  Conectado
                </div>
              </div>
            </div>
            
            <!-- Mini List of Contacts -->
            <div class="flex flex-col gap-2">
              <span class="text-xs text-gray-500 uppercase tracking-wider font-semibold">Leads Recientes</span>
              <div class="flex flex-col gap-2.5">
                <!-- Lead 1 -->
                <div class="flex items-center justify-between rounded-xl bg-white/[0.02] hover:bg-white/[0.04] p-3 border border-white/5 transition-colors">
                  <div class="flex items-center gap-3">
                    <div class="h-8 w-8 rounded-full bg-gradient-to-br from-brand-purple to-indigo-500 flex items-center justify-center text-white font-semibold text-xs">
                      AM
                    </div>
                    <div>
                      <div class="font-semibold text-white text-xs">Andrés Mendoza</div>
                      <div class="text-[10px] text-gray-500 mt-0.5">Soporte Técnico Especializado</div>
                    </div>
                  </div>
                  <span class="rounded-full bg-yellow-500/10 border border-yellow-500/20 px-2 py-0.5 text-[10px] text-yellow-500 font-medium">
                    Interesado
                  </span>
                </div>
                <!-- Lead 2 -->
                <div class="flex items-center justify-between rounded-xl bg-white/[0.02] hover:bg-white/[0.04] p-3 border border-white/5 transition-colors">
                  <div class="flex items-center gap-3">
                    <div class="h-8 w-8 rounded-full bg-gradient-to-br from-brand-green to-teal-500 flex items-center justify-center text-white font-semibold text-xs">
                      CB
                    </div>
                    <div>
                      <div class="font-semibold text-white text-xs">Camila Beltrán</div>
                      <div class="text-[10px] text-gray-500 mt-0.5">Reserva Mesa Terraza (4 pers)</div>
                    </div>
                  </div>
                  <span class="rounded-full bg-brand-green/10 border border-brand-green/20 px-2 py-0.5 text-[10px] text-brand-green font-medium">
                    Agendado
                  </span>
                </div>
                <!-- Lead 3 -->
                <div class="flex items-center justify-between rounded-xl bg-white/[0.02] hover:bg-white/[0.04] p-3 border border-white/5 transition-colors">
                  <div class="flex items-center gap-3">
                    <div class="h-8 w-8 rounded-full bg-gradient-to-br from-gray-600 to-slate-700 flex items-center justify-center text-white font-semibold text-xs">
                      RP
                    </div>
                    <div>
                      <div class="font-semibold text-white text-xs">Roberto Pérez</div>
                      <div class="text-[10px] text-gray-500 mt-0.5">Consulta de Precios y FAQs</div>
                    </div>
                  </div>
                  <span class="rounded-full bg-blue-500/10 border border-blue-500/20 px-2 py-0.5 text-[10px] text-blue-500 font-medium">
                    Resuelto
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
